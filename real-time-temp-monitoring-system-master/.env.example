# ═══════════════════════════════════════════════════════════════════════
# TEMPERATURE MONITORING SYSTEM - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env to version control!
# ═══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# 📧 GMAIL SMTP CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────
# Your Gmail email address (the one sending alerts)
EMAIL_USER=kuldeep.rathod021@gmail.com

# Gmail App Password (NOT your regular password!)
# Generate at: https://myaccount.google.com/apppasswords
# Steps:
#   1. Enable 2-Factor Authentication on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select "Mail" and "Windows Computer"
#   4. Copy the generated 16-character password
# WARNING: Keep this SECRET - treat it like a password!
EMAIL_PASS=lgzhxwmeudyzcjvd


# Recipient email address (who receives the alerts)
# Can be the same as EMAIL_USER or a different email
RECIPIENT_EMAIL=kuldeep.rathod021@gmail.com

# ─────────────────────────────────────────────────────────────────────────
# 🌡️ TEMPERATURE ALERT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────
# Temperature threshold in Celsius
# Alert will trigger when temperature exceeds this value
TEMP_THRESHOLD=35

# Alert cooldown period in seconds
# Prevents alert spam - minimum wait time between consecutive alerts
# Default: 3600 seconds (1 hour)
# Tip: Set to 300 (5 min) for testing, 3600 (1 hour) for production
ALERT_COOLDOWN=3600

# ─────────────────────────────────────────────────────────────────────────
# Optional: Firebase Configuration (if you want to log alerts to Firebase)
# ─────────────────────────────────────────────────────────────────────────
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
# DEVICE_ID=ESP32-001
# DEVICE_NAME=Main Room Temperature Sensor
